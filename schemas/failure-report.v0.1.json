{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ralfferreira/email-failure-lab/main/schemas/failure-report.v0.1.json",
  "title": "Email Failure Lab FailureReport v0.1",
  "description": "Stable JSON output contract for email-lab explain reports with schemaVersion 0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "category",
    "bounceType",
    "recommendedAction",
    "confidence",
    "explanation",
    "appGuidance",
    "signals"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "category": {
      "$ref": "#/$defs/failureCategory"
    },
    "bounceType": {
      "$ref": "#/$defs/bounceType"
    },
    "recommendedAction": {
      "$ref": "#/$defs/recommendedAction"
    },
    "confidence": {
      "$ref": "#/$defs/confidence"
    },
    "explanation": {
      "type": "string",
      "minLength": 1
    },
    "appGuidance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    }
  },
  "$defs": {
    "failureCategory": {
      "type": "string",
      "enum": [
        "invalid_recipient",
        "mailbox_full",
        "authentication_failure",
        "policy_rejection",
        "rate_limited",
        "temporary_failure",
        "content_rejected",
        "provider_error",
        "unknown"
      ]
    },
    "bounceType": {
      "type": "string",
      "enum": [
        "hard",
        "soft",
        "unknown"
      ]
    },
    "recommendedAction": {
      "type": "string",
      "enum": [
        "suppress_recipient",
        "retry_later",
        "fix_domain_authentication",
        "reduce_sending_rate",
        "review_content",
        "investigate_provider",
        "contact_recipient",
        "no_action_required",
        "unknown"
      ]
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "score"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "level": {
                "const": "low"
              }
            },
            "required": [
              "level"
            ]
          },
          "then": {
            "properties": {
              "score": {
                "maximum": 59
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "level": {
                "const": "medium"
              }
            },
            "required": [
              "level"
            ]
          },
          "then": {
            "properties": {
              "score": {
                "minimum": 60,
                "maximum": 89
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "level": {
                "const": "high"
              }
            },
            "required": [
              "level"
            ]
          },
          "then": {
            "properties": {
              "score": {
                "minimum": 90
              }
            }
          }
        }
      ],
      "properties": {
        "level": {
          "$ref": "#/$defs/confidenceLevel"
        },
        "score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99
        }
      }
    },
    "confidenceLevel": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value",
        "weight"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "smtp_code"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "pattern": "^[45][0-9]{2}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "enhanced_status_code"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "pattern": "^[245]\\.[0-9]{1,3}\\.[0-9]{1,3}$"
              }
            }
          }
        }
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/signalKind"
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        }
      }
    },
    "signalKind": {
      "type": "string",
      "enum": [
        "smtp_code",
        "enhanced_status_code",
        "matched_phrase"
      ]
    }
  }
}
